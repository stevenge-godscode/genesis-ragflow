# Core
RAGFLOW_IMAGE=infiniflow/ragflow:latest
DOCKERHUB_MIRROR_PREFIX=
TZ=Asia/Shanghai

# Exposed port on host (nginx should proxy this)
RAGFLOW_HTTP_PORT=18081

# Database
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ragflow
MYSQL_USER=ragflow
MYSQL_PASSWORD=change_me_app

# Redis
REDIS_PASSWORD=change_me_redis

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=ragflow

# Search engine
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change_me_opensearch

# RAGFlow app
RAGFLOW_BASE_URL=https://ragflow.example.com
RAGFLOW_API_KEY=change_me_api_key

# Optional model endpoint (example)
OPENAI_API_BASE=
OPENAI_API_KEY=
OPENAI_MODEL=
